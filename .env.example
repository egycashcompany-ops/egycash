# ECMS environment configuration.
# Every variable is validated by the Zod env schema at boot (apps/api/src/infrastructure/config/env.ts).
# Copy to .env for local development — the defaults below work with `docker compose up -d`.

# ── Runtime ────────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=3000
LOG_LEVEL=debug

# ── Data stores ────────────────────────────────────────────────────────────
# Local docker-compose runs a single-node replica set (required for transactions).
MONGO_URI=mongodb://localhost:27017/ecms?replicaSet=rs0&directConnection=true
REDIS_URL=redis://localhost:6379

# ── Auth (ADR-006) ─────────────────────────────────────────────────────────
# Generate real secrets with: openssl rand -hex 32
JWT_ACCESS_SECRET=dev-only-access-secret-change-me
JWT_ACCESS_TTL_SECONDS=900
REFRESH_TTL_DAYS=7
# Set true behind HTTPS (staging/production).
COOKIE_SECURE=false

# ── HTTP ───────────────────────────────────────────────────────────────────
CORS_ORIGINS=http://localhost:5173

# ── Observability ──────────────────────────────────────────────────────────
# Error tracking (Review R31). Leave empty to disable.
SENTRY_DSN=
# Slow-query telemetry threshold in ms (Review R30).
SLOW_QUERY_MS=200

# ── Seed data (development only — synthetic, never production values) ──────
SEED_ADMIN_EMAIL=admin@ecms.local
SEED_ADMIN_PASSWORD=Admin#2026!ecms
SEED_HR_EMAIL=hr@ecms.local
SEED_HR_PASSWORD=HrUser#2026!ecms

# ── Frontend (apps/web, Vite) ──────────────────────────────────────────────
VITE_API_BASE_URL=http://localhost:3000/api/v1

# ── File storage (ADR-010, Sprint 3.1) ─────────────────────────────────────
# Driver: local | railway | s3 | minio | azure
STORAGE_DRIVER=local
STORAGE_LOCAL_ROOT=./storage
# Set automatically by Railway when a volume is attached (driver: railway).
RAILWAY_VOLUME_MOUNT_PATH=
# HMAC secret for app-signed download URLs (openssl rand -hex 32).
STORAGE_SIGNING_SECRET=dev-only-file-signing-secret
SIGNED_URL_TTL_SECONDS=300
# Absolute base URL of the api — used in app-signed download URLs.
API_PUBLIC_URL=http://localhost:3000
# Platform-wide upload cap; categories can only tighten it.
MAX_UPLOAD_MB=25
# S3 / MinIO (driver: s3 | minio; MinIO also requires S3_ENDPOINT)
S3_BUCKET=
S3_REGION=us-east-1
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
S3_ENDPOINT=
# Azure Blob (driver: azure)
AZURE_STORAGE_CONNECTION_STRING=
AZURE_STORAGE_CONTAINER=ecms-files
