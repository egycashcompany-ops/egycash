{
  "name": "@ecms/api",
  "version": "2.1.0",
  "private": true,
  "description": "ECMS backend: Express API + BullMQ worker (two entrypoints)",
  "type": "module",
  "scripts": {
    "dev": "tsx watch --env-file=../../.env src/server.ts",
    "dev:worker": "tsx watch --env-file=../../.env src/worker.ts",
    "seed": "tsx --env-file=../../.env src/seed.ts",
    "build": "tsup",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "start": "node dist/server.js",
    "start:worker": "node dist/worker.js",
    "test:unit": "vitest run src",
    "test:integration": "vitest run tests"
  },
  "dependencies": {
    "@ecms/contracts": "*",
    "@sentry/node": "^8.48.0",
    "argon2": "^0.41.1",
    "bullmq": "^5.34.0",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.5",
    "express": "^4.21.2",
    "express-mongo-sanitize": "^2.2.0",
    "helmet": "^8.0.0",
    "ioredis": "^5.4.2",
    "jsonwebtoken": "^9.0.2",
    "mongoose": "^8.9.5",
    "otplib": "^12.0.1",
    "pino": "^9.6.0",
    "pino-http": "^10.4.0",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@types/cookie-parser": "^1.4.8",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/jsonwebtoken": "^9.0.7",
    "@types/node": "^22.10.0",
    "@types/supertest": "^6.0.2",
    "mongodb-memory-server": "^10.1.3",
    "pino-pretty": "^13.0.0",
    "supertest": "^7.0.0",
    "tsup": "^8.3.5",
    "tsx": "^4.19.2",
    "typescript": "^5.7.3",
    "vitest": "^3.0.0"
  }
}
